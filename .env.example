# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=real_estate

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama Cloud / Remote Inference
# Set OLLAMA_HOST to your cloud Ollama endpoint (e.g., https://ollama.myserver.com)
# Leave as localhost:11434 for local Docker Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=

# Models
EMBED_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5:14b

# Retrieval
RETRIEVAL_TOP_K=5
FAST_RESPONSE_TIMEOUT=0.3
RAG_TIMEOUT=2.0
