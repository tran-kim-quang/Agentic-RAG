# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION=real_estate

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama Dual-Host Setup
# EMBED_HOST: local Ollama for fast embedding (no auth needed)
# LLM_HOST:  Ollama Cloud for chat generation (requires API key)
OLLAMA_EMBED_HOST=http://localhost:11434
OLLAMA_LLM_HOST=https://api.ollama.com

# API Key for Ollama Cloud (get from https://ollama.com/settings/keys)
OLLAMA_API_KEY=

# Models
# Local embed model
EMBED_MODEL=nomic-embed-text
# Cloud LLM model — see available models at https://ollama.com/api/tags
LLM_MODEL=kimi-k2.6

# ── Unified LLM Provider ────────────────────────────────────────
# Supported: ollama | openai | openai-compatible
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# OpenAI-compatible provider (vLLM, TGI, Together, Groq, etc.)
# When LLM_PROVIDER=openai or openai-compatible, set these:
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_API_KEY=sk-...

# Retrieval
RETRIEVAL_TOP_K=5
FAST_RESPONSE_TIMEOUT=0.3
RAG_TIMEOUT=2.0
